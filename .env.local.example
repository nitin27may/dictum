# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# ── OpenAI ────────────────────────────────────────────────
# API key — used when no key is set in the Settings UI.
VITE_OPENAI_API_KEY=sk-...

# Optional: override the Whisper model (default: whisper-1)
# VITE_OPENAI_WHISPER_MODEL=whisper-1

# ── Azure OpenAI ──────────────────────────────────────────
# Endpoint for your Azure OpenAI resource
VITE_AZURE_ENDPOINT=https://resource.openai.azure.com

# Azure OpenAI API key
VITE_AZURE_API_KEY=KEY

# Whisper deployment name (default: whisper)
VITE_AZURE_WHISPER_DEPLOYMENT=gpt-4o-mini-transcribe

# GPT deployment name for Smart Keywords rephrase (default: gpt-4o-mini)
VITE_AZURE_GPT_DEPLOYMENT=gpt-4.1-mini

# API version (default: 2024-02-01)
VITE_AZURE_API_VERSION=2024-12-01-preview
