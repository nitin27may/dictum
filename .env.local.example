# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# OpenAI API key — used when no key is set in the Settings UI.
# Useful for development without opening Settings every time.
VITE_OPENAI_API_KEY=sk-...

# Optional: override the Whisper model (default: whisper-1)
# VITE_OPENAI_WHISPER_MODEL=whisper-1
